{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "module": "esnext",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "esModuleInterop": true,
    "importHelpers": true,
    "target": "es2022",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@arcani/shared-domain": ["libs/shared/domain/src/index.ts"],
      "@arcani/core-reactive-engine": [
        "libs/core/reactive-engine/src/index.ts"
      ],
      "@arcani/shared-auth": ["libs/shared/auth/src/index.ts"],
      "@arcani/data-access-api-client": [
        "libs/data-access/api-client/src/index.ts"
      ],
      "@arcani/data-access-db-entities": [
        "libs/data-access/db-entities/src/index.ts"
      ],
      "@arcani/data-access-subscribers": [
        "libs/data-access/subscribers/src/index.ts"
      ],
      "@arcani/data-access-migrations": [
        "libs/data-access/migrations/src/index.ts"
      ],
      "@arcani/core-studio-logic": ["libs/core/studio-logic/src/index.ts"],
      "@arcani/shared-ui": ["libs/shared/ui/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
